  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "system": ["pf2e"],
  "esmodules": ["scripts/main.js"],
  "styles": ["styles/module.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "authors": [
    {
      "name": "Michael 'Jesuisfrog' Baglio"
    }
  ],
  "url": "https://github.com/jesuisfrog/pf2e-inline-automation-helper",
  "manifest": "https://raw.githubusercontent.com/jesuisfrog/pf2e-inline-automation-helper/refs/heads/main/module.json",
  "download": " https://github.com/jesuisfrog/pf2e-inline-automation-helper/releases/download/v1.0.0/module.zip"
}
